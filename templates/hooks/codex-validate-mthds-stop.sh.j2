{% raw %}#!/usr/bin/env bash
# Codex Stop hook: lint, format, and validate changed .mthds files at end of turn
# Finds changed .mthds files via git diff, then runs (in order):
#   1. plxt lint                  — TOML/schema-level linting (blocks on errors)
#   2. plxt fmt                   — auto-format the file (only if lint passes)
#   3. mthds-agent validate bundle — semantic validation (blocks or warns)
# Blocks if plxt or mthds-agent is not installed.
# Uses Node.js for JSON parsing (guaranteed on PATH since mthds-agent requires it).

set -euo pipefail

# --- Read stdin (Stop hook JSON) — consume but we don't need fields from it ---
cat > /dev/null

# --- Find changed .mthds files ---
MTHDS_FILES=()

# Unstaged changes
while IFS= read -r file; do
  [[ -n "$file" && "$file" == *.mthds && -f "$file" ]] && MTHDS_FILES+=("$file")
done < <(git diff --name-only 2>/dev/null || true)

# Staged changes
while IFS= read -r file; do
  [[ -n "$file" && "$file" == *.mthds && -f "$file" ]] && MTHDS_FILES+=("$file")
done < <(git diff --name-only --cached 2>/dev/null || true)

# Untracked .mthds files
while IFS= read -r file; do
  [[ -n "$file" && "$file" == *.mthds && -f "$file" ]] && MTHDS_FILES+=("$file")
done < <(git ls-files --others --exclude-standard '*.mthds' 2>/dev/null || true)

# Deduplicate (bash 3.2 compatible — no readarray on macOS)
if [[ ${#MTHDS_FILES[@]} -gt 0 ]]; then
  UNIQUE_MTHDS_FILES=()
  while IFS= read -r file; do
    UNIQUE_MTHDS_FILES+=("$file")
  done < <(printf '%s\n' "${MTHDS_FILES[@]}" | sort -u)
  MTHDS_FILES=("${UNIQUE_MTHDS_FILES[@]}")
fi

# No changed .mthds files — pass silently
if [[ ${#MTHDS_FILES[@]} -eq 0 ]]; then
  exit 0
fi

# --- Require Node.js for JSON output ---
if ! command -v node &>/dev/null; then
  printf '{"decision":"block","reason":"Missing required runtime: Node.js (required by mthds-agent)"}\n'
  exit 0
fi

# --- JSON helper: output a {"decision":"block","reason":...} JSON object ---
_block() {
  node -e "process.stdout.write(JSON.stringify({decision:'block',reason:process.argv[1]})+'\n')" "$1" \
    || printf '{"decision":"block","reason":"Hook error: could not format block reason"}\n'
}

# --- Require plxt and mthds-agent on PATH ---
MISSING=""
{% endraw -%}
command -v plxt &>/dev/null || MISSING="plxt (install via: {{ plxt_install_cmd }})"
command -v mthds-agent &>/dev/null || MISSING="${MISSING:+$MISSING, }mthds-agent (install via: {{ mthds_install_cmd }})"
{% raw -%}
if [[ -n "$MISSING" ]]; then
  _block "Missing required CLI tool(s): $MISSING"
  exit 0
fi

TMPOUT=$(mktemp)
TMPERR=$(mktemp)
trap 'rm -f "$TMPOUT" "$TMPERR"' EXIT

ALL_ERRORS=""

for FILE_PATH in "${MTHDS_FILES[@]}"; do

  # =====================================================================
  # STAGE 1: plxt lint — TOML/schema-level linting
  # =====================================================================
  LINT_EXIT=0
  plxt lint --quiet "$FILE_PATH" >"$TMPOUT" 2>"$TMPERR" || LINT_EXIT=$?

  if [[ "$LINT_EXIT" -ne 0 ]]; then
    LINT_OUTPUT=$(cat "$TMPERR")
    [[ -z "$LINT_OUTPUT" ]] && LINT_OUTPUT=$(cat "$TMPOUT")
    [[ -z "$LINT_OUTPUT" ]] && LINT_OUTPUT="lint exited with code $LINT_EXIT (no output)"
    ALL_ERRORS="${ALL_ERRORS}TOML/schema lint errors in $FILE_PATH:\n$LINT_OUTPUT\n\n"
    continue
  fi

  # =====================================================================
  # STAGE 2: plxt fmt — auto-format the file in-place (lint passed)
  # =====================================================================
  FMT_EXIT=0
  plxt fmt "$FILE_PATH" >"$TMPOUT" 2>"$TMPERR" || FMT_EXIT=$?
  if [[ "$FMT_EXIT" -ne 0 ]]; then
    FMT_ERR=$(cat "$TMPERR")
    echo "[mthds-hook] Warning: plxt fmt failed on $FILE_PATH (exit $FMT_EXIT): ${FMT_ERR:-no output}" >&2
  fi

  # =====================================================================
  # STAGE 3: mthds-agent validate bundle — semantic validation
  # =====================================================================
  PARENT_DIR=$(dirname "$FILE_PATH")

  EXIT_CODE=0
  mthds-agent validate bundle "$FILE_PATH" -L "$PARENT_DIR/" >"$TMPOUT" 2>"$TMPERR" || EXIT_CODE=$?

  if [[ "$EXIT_CODE" -eq 0 ]]; then
    continue
  fi

  # Error path: parse stderr JSON and decide
  ERR_JSON=$(cat "$TMPERR")

  STAGE3_RESULT=$(node -e "
const file = process.argv[1];
const exitCode = process.argv[2];
let parsed;
try { parsed = JSON.parse(process.argv[3]); } catch { parsed = null; }

if (!parsed || !parsed.error) {
  process.stderr.write('[mthds-hook] Warning: mthds-agent validate exited with code ' + exitCode + ' but produced unexpected output:\n');
  process.stderr.write((process.argv[3] || '') + '\n');
  process.exit(0);
}

const domain = parsed.error_domain || '';
const message = parsed.message || '';
const hint = parsed.hint || '';
const valErrs = Array.isArray(parsed.validation_errors) ? parsed.validation_errors : [];
const dryRunErr = parsed.dry_run_error || null;

if (domain === 'config' || domain === 'runtime') {
  process.stderr.write('[mthds-hook] Warning: ' + message + '\n');
  if (hint) process.stderr.write('[mthds-hook] Hint: ' + hint + '\n');
  process.exit(0);
}

if (valErrs.length > 0) {
  const pipes = [...new Set(valErrs.map(e => e.pipe_code || 'unknown'))].join(', ');
  const details = valErrs.map(e => '- [' + (e.pipe_code || 'unknown') + '] ' + e.message).join('\n');
  process.stdout.write(file + ' has ' + valErrs.length + ' validation error(s) in pipe(s): ' + pipes + '\n' + details);
  process.exit(0);
}

if (dryRunErr) {
  process.stderr.write('[mthds-hook] Warning (dry-run): ' + message + '\n');
  process.stderr.write('[mthds-hook] Dry-run detail: ' + dryRunErr + '\n');
  if (hint) process.stderr.write('[mthds-hook] Hint: ' + hint + '\n');
  process.exit(0);
}

process.stderr.write('[mthds-hook] Warning: ' + (parsed.error_type || '') + ' — ' + message + '\n');
if (hint) process.stderr.write('[mthds-hook] Hint: ' + hint + '\n');
process.exit(0);
" "$FILE_PATH" "$EXIT_CODE" "$ERR_JSON" 2>&1 1>"$TMPOUT") || true

  BLOCK_REASON=$(cat "$TMPOUT")
  if [[ -n "$BLOCK_REASON" ]]; then
    ALL_ERRORS="${ALL_ERRORS}${BLOCK_REASON}\n\n"
  fi

done

# --- Report results ---
if [[ -n "$ALL_ERRORS" ]]; then
  REASON=$(printf "$ALL_ERRORS" | sed '/^$/d')
  _block "$REASON"
fi

exit 0
{% endraw %}
